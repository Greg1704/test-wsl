# Variables de entorno de CuotApp.
# Copiá este archivo a .env y completá los valores. El .env real NO se commitea
# (tiene secrets); este .example SÍ se commitea, sin valores sensibles.

# Postgres de desarrollo. docker compose up -d postgres levanta:
#   user=app  pass=dev  db=cuotas
DATABASE_URL="postgresql://app:dev@localhost:5432/cuotas?schema=public"

# SOLO PRODUCCIÓN (Vercel + Neon): conexión DIRECTA (sin pooling) para las
# migraciones. En prod, DATABASE_URL apunta al endpoint POOLED de Neon (runtime
# serverless) y DIRECT_URL al endpoint directo (DDL de `prisma migrate deploy`).
# En desarrollo NO hace falta: si no está, prisma.config.ts cae a DATABASE_URL.
# DIRECT_URL=""

# Base de datos exclusiva para los tests E2E (Playwright). Usá una DB separada
# de la de desarrollo para no pisar tus datos.
DATABASE_URL_TEST="postgresql://app:dev@localhost:5432/cuotas_test?schema=public"

# Better Auth. Generá un secret aleatorio y largo con:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# URL pública de la app (la usa el auth client en el browser).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Envío de mails (Resend). API key del dashboard de resend.com.
RESEND_API_KEY=""
# Remitente de los mails. En dev podés usar el dominio de prueba de Resend sin
# verificar nada: "CuotApp <onboarding@resend.dev>". En prod, un dominio propio
# verificado (SPF/DKIM).
EMAIL_FROM="CuotApp <onboarding@resend.dev>"

# Secret que protege el endpoint del cron del reporte mensual
# (/api/cron/monthly-report). Generá uno con: openssl rand -base64 32
# En Vercel, al definirlo, el cron lo manda como header Authorization: Bearer.
CRON_SECRET=""
