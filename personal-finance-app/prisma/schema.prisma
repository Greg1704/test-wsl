generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String?
  emailVerified   Boolean  @default(false)
  image           String?
  defaultCurrency String   @default("ARS")
  // Opt-in al mail mensual de deudas (RF de mails). Default false: solo lo recibe
  // quien lo activa en Configuración. Lo dispara el cron /api/cron/monthly-report.
  monthlyReportEnabled Boolean @default(false)
  // Opt-in al seguimiento de límite de crédito + utilización. Default false: no fuerza
  // al usuario a cargar límites ni cotizaciones. Cuando está activo, el límite se carga
  // por tarjeta (opcional) en ESTA moneda principal (defaultCurrency) y las compras en
  // otra moneda piden la cotización al confirmar (Purchase.limitRate). Ver ARCHITECTURE.
  trackCreditLimits Boolean @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sessions        Session[]
  accounts        Account[]
  cards           Card[]
  purchases       Purchase[]
  categories      Category[]
  rates           ExchangeRate[]
  incomeEntries   IncomeEntry[]
  savingsBalances SavingsBalance[]
  subscriptions   Subscription[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Card {
  id             String    @id @default(cuid())
  userId         String
  type           CardType  @default(CREDIT) // crédito (con ciclo de facturación) o débito
  name           String    // nombre identificatorio de la tarjeta ("Tarjeta principal")
  owner          String?   // dueño de la tarjeta (para tarjetas ajenas que se deben pagar)
  bank           String    // banco emisor ("Galicia", "Santander"… o nombre libre)
  brand          String?
  last4          String    // últimos 4 dígitos (obligatorio)
  // El ciclo de facturación y el vencimiento solo aplican a tarjetas de CRÉDITO:
  // el débito gasta contra el saldo al instante (sin cierre/vencimiento). Nullables.
  expirationDate DateTime? @db.Date // vencimiento de la tarjeta (fin del mes MM/AA)
  closingDay     Int?
  dueDay         Int?
  // Monedas que opera la tarjeta. En AR un mismo plástico suele tener resumen en ARS
  // y en USD bajo el MISMO ciclo (cierre/vencimiento). La compra elige entre estas;
  // cada Installment/Purchase guarda su propia `currency`. Al menos una (validado en Zod).
  currencies     String[]  @default(["ARS"])
  // Límite de crédito en centavos, expresado SIEMPRE en la moneda principal del USUARIO
  // (User.defaultCurrency), no en la de la tarjeta: el límite es un tope único y las
  // compras en otra moneda se convierten a él (Purchase.limitRate). Solo aplica a CRÉDITO;
  // nullable porque el débito no lo tiene y, con el seguimiento activo, el usuario puede
  // dejarlo vacío por tarjeta. Habilita la barra de utilización de esa tarjeta.
  creditLimitCents BigInt?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  purchases     Purchase[]
  subscriptions Subscription[]

  @@index([userId])
}

enum CardType {
  CREDIT
  DEBIT
}

model Purchase {
  id                      String        @id @default(cuid())
  userId                  String
  // CREDIT genera cuotas (Installment); DEBIT/TRANSFER/CASH son pago único que
  // descuenta del ahorro y NO materializa cuotas (ver docs/ARCHITECTURE.md).
  paymentMethod           PaymentMethod @default(CREDIT)
  cardId                  String? // nulo para transferencia/efectivo (no hay tarjeta)
  categoryId              String?
  description             String
  merchant                String?
  totalAmountCents        BigInt
  currency                String        @default("ARS")
  totalInstallments       Int
  purchaseDate            DateTime      @db.Date
  firstInstallmentDueDate DateTime      @db.Date
  interestRateMonthly     Decimal?      @db.Decimal(8, 4)
  // Cotización usada para imputar esta compra al límite de crédito cuando su moneda
  // difiere de la principal del usuario: unidades de la moneda principal por 1 unidad de
  // `currency`, capturada al confirmar la compra (snapshot, no se recalcula). null si la
  // compra ya está en la moneda principal o si el seguimiento de límite estaba apagado.
  limitRate               Decimal?      @db.Decimal(18, 6)
  notes                   String?
  createdAt               DateTime      @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  card         Card?         @relation(fields: [cardId], references: [id], onDelete: Cascade)
  category     Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  installments Installment[]

  @@index([userId])
  @@index([cardId])
  @@index([userId, paymentMethod])
}

enum PaymentMethod {
  CREDIT
  DEBIT
  TRANSFER
  CASH
}

model Installment {
  id                String            @id @default(cuid())
  purchaseId        String
  installmentNumber Int
  dueDate           DateTime          @db.Date
  amountCents       BigInt
  currency          String            @default("ARS")
  status            InstallmentStatus @default(PENDING)
  // Al marcar PAID, indica si esta cuota se descontó del ahorro (puente cuota↔ahorro,
  // RF-ahorros). Solo relevante para cuotas de crédito pagadas.
  paidFromSavings   Boolean           @default(false)
  paidAt            DateTime?
  createdAt         DateTime          @default(now())

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([purchaseId])
  @@index([dueDate])
}

enum InstallmentStatus {
  PENDING
  PAID
  OVERDUE
}

model Category {
  id        String    @id @default(cuid())
  userId    String
  name      String
  color     String?
  icon      String?
  createdAt DateTime  @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  purchases     Purchase[]
  subscriptions Subscription[]

  @@index([userId])
}

model ExchangeRate {
  id           String   @id @default(cuid())
  userId       String
  fromCurrency String
  toCurrency   String
  rate         Decimal  @db.Decimal(18, 6)
  validFrom    DateTime @db.Date

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Ingreso mensual fechado por vigencia, por moneda. El ingreso de un mes es la
/// entrada con mayor `validFrom <= mes`: cambiarlo inserta una entrada nueva con
/// `validFrom` = mes actual, y los meses pasados conservan su valor automáticamente.
model IncomeEntry {
  id          String   @id @default(cuid())
  userId      String
  currency    String // "ARS" | "USD"
  amountCents BigInt
  validFrom   DateTime @db.Date // primer día del mes desde el que aplica
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, currency, validFrom])
}

/// Ancla del ahorro por moneda: saldo declarado por el usuario a una fecha. El saldo
/// real de cualquier mes se computa al leer (ancla + ingresos − gastos no-crédito −
/// cuotas pagadas-desde-ahorros); no es una columna mutable. Ver src/server/lib/savings.ts.
model SavingsBalance {
  id          String   @id @default(cuid())
  userId      String
  currency    String
  amountCents BigInt // saldo declarado a la fecha `asOf`
  asOf        DateTime @db.Date // primer día del mes del saldo declarado
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, currency])
}

enum SubMethod {
  CREDIT
  DEBIT
}

/// Suscripción / gasto recurrente mensual (Netflix, Spotify…). Entidad HERMANA de Purchase,
/// no una compra: la definición vive para siempre y los cobros de cada mes se computan al
/// vuelo (src/server/lib/subscriptions.ts). Solo se materializan las DESVIACIONES en
/// SubscriptionCharge (marcar pago / saltear un mes). Ver docs/BACKLOG.md #6.
model Subscription {
  id              String    @id @default(cuid())
  userId          String
  name            String // "Netflix"
  amountCents     BigInt // monto mensual en centavos
  currency        String    @default("ARS")
  paymentMethod   SubMethod // CREDIT | DEBIT (efectivo/transferencia fuera por ahora)
  // Requerida si CREDIT (para atarla al límite/calendario de esa tarjeta); opcional en débito.
  cardId          String?
  // Ancla de recurrencia: define el DÍA del cobro y desde qué mes corre (7 jun → 7 jul → …).
  firstChargeDate DateTime  @db.Date
  // Baja PROGRAMADA (opcional): desde este mes deja de generar cobros. null = sin fecha.
  endDate         DateTime? @db.Date
  // Archivado (soft): fuera de la lista activa y sin generar cobros nuevos, pero sus cobros
  // PAGADOS siguen contando en el historial de ahorro. Se archiva a mano cuando tiene pagos
  // (no se puede borrar sin perder el historial); las sin pagos se borran de verdad.
  isActive        Boolean   @default(true)
  categoryId      String?
  // Cotización snapshot (igual que Purchase.limitRate) para imputar al límite cuando la
  // suscripción de crédito está en una moneda distinta a la principal del usuario: unidades
  // de la principal por 1 de `currency`. null si está en la principal o no es crédito.
  limitRate       Decimal?  @db.Decimal(18, 6)
  createdAt       DateTime  @default(now())

  user     User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  card     Card?                @relation(fields: [cardId], references: [id], onDelete: Cascade)
  category Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  charges  SubscriptionCharge[]

  @@index([userId])
  @@index([cardId])
}

enum ChargeStatus {
  PAID
  SKIPPED
}

/// Override DISPERSO de un cobro puntual: existe SOLO cuando el usuario tocó ese mes
/// (marcarlo pago o saltearlo). Sin fila ⇒ el mes está pendiente, contado, al monto de la
/// definición. `amountCentsOverride` cubre el mes que salió distinto. Ver subscriptions.ts.
model SubscriptionCharge {
  id                  String       @id @default(cuid())
  subscriptionId      String
  periodMonth         DateTime     @db.Date // primer día del mes al que aplica
  status              ChargeStatus // PAID | SKIPPED
  // Al marcar PAID, si el pago salió del ahorro (puente cobro↔ahorro, igual que las cuotas).
  paidFromSavings     Boolean      @default(true)
  paidAt              DateTime?
  amountCentsOverride BigInt?
  createdAt           DateTime     @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, periodMonth])
  @@index([subscriptionId])
}
